# Database
DATABASE_URL="mysql://user:password@localhost:3306/binbogabal"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# QNB Pay
QNB_PAY_MERCHANT_ID="your-merchant-id"
QNB_PAY_MERCHANT_KEY="your-merchant-key"
QNB_PAY_MERCHANT_SALT="your-merchant-salt"
QNB_PAY_API_URL="https://api.qnbpay.com.tr"
QNB_PAY_SANDBOX="true"

# Dia Proxy API
DIA_PROXY_URL="http://localhost:3500"
DIA_PROXY_API_KEY="your-proxy-api-key"
DIA_PROXY_ORDER_ACTION=""   # ERP sipariş kayıt action adı (ör. scf_siparis_kaydet)
DIA_PROXY_STOCK_DEPO_KODU="41908"
DIA_PROXY_FIRMA_KODU="1"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Binboğa Kooperatif Balı"
