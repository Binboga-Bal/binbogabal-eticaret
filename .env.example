# Database
DATABASE_URL="mysql://user:password@localhost:3306/binbogabal"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# QNB Pay
QNB_PAY_APP_ID="your-app-id"           # configs.php → app_id
QNB_PAY_APP_SECRET="your-app-secret"   # configs.php → app_secret
QNB_PAY_MERCHANT_KEY="your-merchant-key"  # configs.php → merchant_key
QNB_PAY_POS_ID="122"                   # Merchant hesabına bağlı POS terminali ID'si
QNB_PAY_SANDBOX="true"                 # false → portal.qnbpay.com.tr (canlı)

# Dia Proxy API
DIA_PROXY_URL="http://localhost:3500"
DIA_PROXY_API_KEY="your-proxy-api-key"
DIA_PROXY_ORDER_ACTION=""   # ERP sipariş kayıt action adı (ör. scf_siparis_kaydet)
DIA_PROXY_STOCK_DEPO_KODU="41908"
DIA_PROXY_FIRMA_KODU="1"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Binboğa Kooperatif Balı"

# Resend (Mail)
RESEND_API_KEY="re_..."
MAIL_FROM="noreply@binbogabal.com"

# Cron
CRON_SECRET="guclu-cron-secret-min-32-karakter"
