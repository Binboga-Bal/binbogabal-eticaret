generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── KULLANICILAR ────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  emailVerifyToken  String?   @unique
  password          String?
  name              String?
  phone             String?
  phoneVerified     Boolean   @default(false)
  avatarUrl         String?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  role              UserRole  @default(CUSTOMER)
  isActive          Boolean   @default(true)
  scheduledDeleteAt DateTime?
  erpCariAdresKey   String?   // ERP cari adres _key (tekrar siparişlerde _key_scf_carikart_adresleri için)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  addresses              Address[]
  orders                 Order[]
  reviews                Review[]
  sessions               Session[]
  accounts               Account[]
  favorites              Favorite[]
  customerCoupons        CustomerCoupon[]
  notificationPreference NotificationPreference?
  consentLogs            ConsentLog[]

  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  CUSTOMER
  EDITOR
  ADMIN
  SUPERADMIN
}

// ─── ADRESLER ────────────────────────────────────────────────────────────────

model Address {
  id           String   @id @default(cuid())
  userId       String
  title        String
  firstName    String
  lastName     String
  phone        String
  city         String
  district     String
  neighborhood String?
  fullAddress  String   @db.Text
  zipCode      String?
  taxNumber    String?
  taxOffice    String?
  isDefault    Boolean  @default(false)
  isBilling    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ─── KATEGORİLER ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  image       String?
  parentId    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  showOnHome  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

// ─── ÜRÜNLER ─────────────────────────────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  shortDescription  String?  @db.Text
  description       String?  @db.Text
  metaTitle         String?
  metaDescription   String?
  images            Json
  isActive          Boolean  @default(true)
  isFeatured        Boolean  @default(false)
  isBestseller      Boolean  @default(false)
  isNew             Boolean  @default(false)
  erpProductCode    String?  @unique
  tasteNotes        Json?
  usageSuggestions  Json?
  relatedProductIds Json     @default("[]")
  bestsellOrder     Int      @default(0)
  featuredOrder     Int      @default(0)
  analysisReportUrl String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  categories      Category[]
  honeyTypes      HoneyType[]
  variants        ProductVariant[]
  reviews         Review[]
  favorites       Favorite[]
  volumeDiscounts VolumeDiscountProduct[]

  @@index([isActive, isFeatured])
  @@index([isActive, isBestseller])
  @@index([isActive, createdAt])
  // pg_trgm GIN — name/shortDescription üzerinde `contains` (LIKE/ILIKE '%q%') aramasını hızlandırır
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([shortDescription(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("products")
}

model HoneyType {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("honey_types")
}

model ProductVariant {
  id               String        @id @default(cuid())
  productId        String
  size             Int
  packagingType    PackagingType @default(GLASS)
  price            Decimal       @db.Decimal(10, 2)
  discountedPrice  Decimal?      @db.Decimal(10, 2)
  stock            Int           @default(0)
  maxOrderQuantity Int?
  sku              String?       @unique
  erpVariantCode   String?       @unique
  erpVariantKey    String?       // ERP stok kartının integer _key değeri (_key_kalemturu)
  erpUnitKey       String?       // ERP birimin integer _key değeri (_key_scf_kalem_birimleri)
  erpKdvRate       Float?        // KDV oranı (%)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

enum PackagingType {
  GLASS
  PLASTIC
}

// ─── SİPARİŞLER ──────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  guestEmail      String?
  guestPhone      String?
  addressId       String?
  shippingAddress Json
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingFee     Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  couponCode      String?
  cargoTrackingNo String?
  cargoCompany    String?
  notes           String?       @db.Text
  cancelReason    String?       @db.Text
  refundReason    String?       @db.Text
  reviewRequested Boolean       @default(false)
  erpOrderCode    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user         User?                @relation(fields: [userId], references: [id])
  address      Address?             @relation(fields: [addressId], references: [id])
  items        OrderItem[]
  transactions PaymentTransaction[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  variantId   String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  productName String
  variantInfo String
  image       String?
  reviewed    Boolean @default(false)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─── ÖDEME ÖNCESİ GEÇİCİ OTURUM ─────────────────────────────────────────────
// QNB_PAY akışında sipariş ödeme onaylanana kadar burada tutulur.
// id = orderNumber (BB-xxx formatı) — aynı zamanda QNBPay invoice_id'si.
// Başarılı callback'te gerçek Order oluşturulur ve bu kayıt silinir.

model CheckoutSession {
  id                 String   @id // orderNumber (BB-xxx) — QNBPay invoice_id
  expiresAt          DateTime
  userId             String?
  shippingAddress    Json
  items              Json     // CartItem dizisi
  subtotal           Decimal  @db.Decimal(10, 2)
  shippingFee        Decimal  @default(0) @db.Decimal(10, 2)
  discount           Decimal  @default(0) @db.Decimal(10, 2)
  total              Decimal  @db.Decimal(10, 2)
  couponCode         String?
  appliedCampaignIds Json     @default("[]")
  notes              String?
  createdAt          DateTime @default(now())

  @@map("checkout_sessions")
}

// ─── ÖDEME ───────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id               String            @id @default(cuid())
  orderId          String
  provider         PaymentProvider   @default(QNB_PAY)
  status           TransactionStatus @default(PENDING)
  amount           Decimal           @db.Decimal(10, 2)
  providerRefId    String?
  providerResponse Json?
  errorCode        String?
  errorMessage     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("payment_transactions")
}

enum PaymentProvider {
  QNB_PAY
  IYZICO
  STRIPE
  MANUAL
  CASH_ON_DELIVERY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─── KAMPANYALAR ─────────────────────────────────────────────────────────────

model Campaign {
  id                String         @id @default(cuid())
  name              String
  slug              String         @unique
  description       String?        @db.Text
  internalNote      String?        @db.Text
  type              CampaignType
  status            CampaignStatus @default(DRAFT)
  priority          Int            @default(0)
  stackable         Boolean        @default(false)
  maxDiscountAmount Decimal?       @db.Decimal(10, 2)
  budgetLimit       Decimal?       @db.Decimal(10, 2)
  budgetUsed        Decimal        @default(0) @db.Decimal(10, 2)
  imageUrl          String?
  ogImageUrl        String?
  startsAt          DateTime
  endsAt            DateTime?
  timezone          String         @default("Europe/Istanbul")
  requiresApproval  Boolean        @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  createdBy         String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  conditions    CampaignCondition[]
  actions       CampaignAction[]
  segments      CampaignSegment[]
  targets       CampaignTarget[]
  coupons       Coupon[]
  abTests       CampaignABTest[]
  usages        CampaignUsage[]
  displays      CampaignDisplay[]
  notifications CampaignNotification[]
  translations  CampaignTranslation[]
  auditLogs     CampaignAuditLog[]
  templates     CampaignTemplate[]

  @@index([status])
  @@index([status, startsAt, endsAt])
  @@map("campaigns")
}

enum CampaignType {
  COUPON
  CART_DISCOUNT
  PRODUCT_DISCOUNT
  FREE_SHIPPING
  BUY_X_PAY_Y
  GIFT_PRODUCT
  FLASH_SALE
  CASHBACK
  BIRTHDAY
  WIN_BACK
  ABANDONED_CART
}

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

model CampaignCondition {
  id         String        @id @default(cuid())
  campaignId String
  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       ConditionType
  operator   String
  value      Json
  logicGroup Int           @default(0)
  sortOrder  Int           @default(0)

  @@index([campaignId])
  @@map("campaign_conditions")
}

enum ConditionType {
  MIN_CART_AMOUNT
  MIN_ITEM_COUNT
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
  SPECIFIC_BRANDS
  CUSTOMER_SEGMENT
  CUSTOMER_ORDER_COUNT
  CUSTOMER_TOTAL_SPEND
  FIRST_ORDER
  DAY_OF_WEEK
  TIME_OF_DAY
  GEOGRAPHIC
  DEVICE_TYPE
  PAYMENT_METHOD
  BIRTHDAY_MONTH
  DAYS_SINCE_LAST_ORDER
}

model CampaignAction {
  id         String     @id @default(cuid())
  campaignId String
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       ActionType
  value      Json
  sortOrder  Int        @default(0)

  @@index([campaignId])
  @@map("campaign_actions")
}

enum ActionType {
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  FREE_SHIPPING
  BUY_X_PAY_Y
  GIFT_PRODUCT
  CASHBACK_POINTS
  FREE_PRODUCT
  CATEGORY_DISCOUNT
}

model CampaignSegment {
  id         String      @id @default(cuid())
  campaignId String
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       SegmentType
  value      Json

  @@index([campaignId])
  @@map("campaign_segments")
}

enum SegmentType {
  ALL_CUSTOMERS
  NEW_CUSTOMERS
  VIP_CUSTOMERS
  INACTIVE_CUSTOMERS
  BIRTHDAY_THIS_MONTH
  SPECIFIC_CUSTOMERS
  CUSTOMER_TAG
  GEOGRAPHIC_SEGMENT
}

model CampaignTarget {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  discount   Decimal? @db.Decimal(10, 2)

  @@index([campaignId])
  @@map("campaign_targets")
}

model CampaignUsage {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id])
  customerId     String?
  orderId        String?
  couponId       String?
  coupon         Coupon?  @relation(fields: [couponId], references: [id])
  discountAmount Decimal  @db.Decimal(10, 2)
  abVariant      String?
  usedAt         DateTime @default(now())

  @@index([campaignId])
  @@index([customerId])
  @@index([usedAt])
  @@map("campaign_usages")
}

model CampaignDisplay {
  id            String      @id @default(cuid())
  campaignId    String
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type          DisplayType
  placement     String
  imageUrl      String?
  title         String?
  subtitle      String?
  ctaText       String?
  ctaUrl        String?
  bgColor       String?
  textColor     String?
  showCountdown Boolean     @default(false)
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)

  @@index([campaignId])
  @@map("campaign_displays")
}

enum DisplayType {
  BANNER
  POPUP
  FLOATING_BAR
  PRODUCT_BADGE
  CART_MESSAGE
}

model HeroSlide {
  id        String   @id @default(cuid())
  imageUrl  String
  linkUrl   String?
  altText   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("hero_slides")
}

model CampaignABTest {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variantName   String
  trafficSplit  Int
  discountValue Decimal  @db.Decimal(10, 2)
  impressions   Int      @default(0)
  conversions   Int      @default(0)
  revenue       Decimal  @default(0) @db.Decimal(10, 2)
  isWinner      Boolean  @default(false)

  @@index([campaignId])
  @@map("campaign_ab_tests")
}

model CampaignNotification {
  id            String           @id @default(cuid())
  campaignId    String
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type          NotificationType
  scheduledAt   DateTime?
  sentAt        DateTime?
  channel       String
  subject       String?
  body          String?          @db.Text
  targetSegment String?
  status        String           @default("PENDING")

  @@index([campaignId])
  @@map("campaign_notifications")
}

enum NotificationType {
  CAMPAIGN_START
  CAMPAIGN_REMINDER
  CAMPAIGN_END
  FAVORITE_DISCOUNT
  ABANDONED_CART
  BIRTHDAY_COUPON
  WIN_BACK_COUPON
}

model CampaignTranslation {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  locale      String
  name        String
  description String?  @db.Text
  ctaText     String?

  @@unique([campaignId, locale])
  @@map("campaign_translations")
}

model CampaignTemplate {
  id          String    @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  name        String
  description String?
  config      Json
  isSystem    Boolean   @default(false)
  createdBy   String
  createdAt   DateTime  @default(now())

  @@index([campaignId])
  @@map("campaign_templates")
}

model CampaignAuditLog {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adminId    String
  action     String
  changes    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([campaignId])
  @@map("campaign_audit_logs")
}

// ─── KUPONLAR ─────────────────────────────────────────────────────────────────

model Coupon {
  id               String       @id @default(cuid())
  campaignId       String?
  campaign         Campaign?    @relation(fields: [campaignId], references: [id])
  code             String       @unique
  description      String?
  discountType     DiscountType @default(PERCENTAGE)
  discountValue    Decimal      @db.Decimal(10, 2)
  minOrderAmount   Decimal?     @db.Decimal(10, 2)
  maxDiscount      Decimal?     @db.Decimal(10, 2)
  maxUses          Int?
  perCustomerLimit Int?         @default(1)
  usedCount        Int          @default(0)
  isActive         Boolean      @default(true)
  isBulk           Boolean      @default(false)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime     @default(now())

  customerCoupons CustomerCoupon[]
  usages          CampaignUsage[]

  @@index([campaignId])
  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model CustomerCoupon {
  id          String    @id @default(cuid())
  userId      String
  couponId    String
  usedAt      DateTime?
  usedInOrder String?
  assignedAt  DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@index([couponId])
  @@map("customer_coupons")
}

// ─── FAVORİLER ───────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("favorites")
}

// ─── BİLDİRİM TERCİHLERİ ─────────────────────────────────────────────────────

model NotificationPreference {
  id                String  @id @default(cuid())
  userId            String  @unique
  orderUpdates      Boolean @default(true)
  favoriteDiscounts Boolean @default(true)
  couponReminders   Boolean @default(true)
  reviewRequests    Boolean @default(true)
  newsletter        Boolean @default(false)
  smsNotifications  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── KVKK ONAY LOGLARI ───────────────────────────────────────────────────────

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  type      String // "kvkk" | "newsletter" | "sms"
  granted   Boolean
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("consent_logs")
}

// ─── DEĞERLENDİRMELER ────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  orderId     String?
  orderItemId String?
  rating      Int
  title       String?
  comment     String?  @db.Text
  images      Json? // string[]
  isApproved  Boolean  @default(false)
  adminReply  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([userId])
  @@map("reviews")
}

// ─── BLOG / İÇERİK ───────────────────────────────────────────────────────────

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?   @db.Text
  content         String    @db.Text
  coverImage      String?
  authorId        String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isPublished, publishedAt])
  @@map("blog_posts")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("faqs")
}

// ─── DIA ERP SYNC ────────────────────────────────────────────────────────────

model ErpSyncLog {
  id          String      @id @default(cuid())
  syncType    ErpSyncType
  status      SyncStatus  @default(PENDING)
  message     String?     @db.Text
  recordCount Int?
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  @@map("erp_sync_logs")
}

enum ErpSyncType {
  PRODUCTS
  STOCK
  ORDERS
  PRICES
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ─── HACİM İNDİRİMİ ──────────────────────────────────────────────────────────

model VolumeDiscount {
  id        String                  @id @default(cuid())
  name      String
  isActive  Boolean                 @default(true)
  // [{minQty: number, discountPercent: number}] — artan sırada
  tiers     Json
  products  VolumeDiscountProduct[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@map("volume_discounts")
}

model VolumeDiscountProduct {
  id               String @id @default(cuid())
  volumeDiscountId String
  productId        String

  volumeDiscount VolumeDiscount @relation(fields: [volumeDiscountId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([volumeDiscountId, productId])
  @@index([productId])
  @@map("volume_discount_products")
}

// ─── SITE AYARLARI ───────────────────────────────────────────────────────────

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("site_settings")
}

// ─── ADMIN RBAC MODÜLü ───────────────────────────────────────────────────────

model AdminUser {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  avatarUrl    String?
  phone        String?
  department   String?
  status       AdminStatus @default(INVITED)
  isSuperAdmin Boolean     @default(false)

  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]
  passwordChangedAt    DateTime?
  mustChangePassword   Boolean   @default(false)
  failedLoginCount     Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  lastLoginCountry     String?

  inviteToken       String?
  inviteTokenExpiry DateTime?
  invitedBy         String?

  previousPasswords String[]

  allowedLoginStart String?
  allowedLoginEnd   String?
  allowedDays       Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles                AdminUserRole[]
  sessions             AdminSession[]
  temporaryPermissions TemporaryPermission[]
  auditLogs            AuditLog[]
  allowedIPs           AdminAllowedIP[]
  scopeAssignments     ScopeAssignment[]

  @@map("admin_users")
}

enum AdminStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
  LOCKED
}

model AdminRole {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  color       String?
  isSystem    Boolean     @default(false)
  parentId    String?
  parent      AdminRole?  @relation("RoleHierarchy", fields: [parentId], references: [id])
  children    AdminRole[] @relation("RoleHierarchy")
  createdBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  permissions AdminRolePermission[]
  users       AdminUserRole[]

  @@index([parentId])
  @@map("admin_roles")
}

model Permission {
  id          String  @id @default(cuid())
  module      String
  action      String
  scope       String  @default("")
  fieldGroup  String?
  description String?
  isSystem    Boolean @default(true)

  rolePermissions AdminRolePermission[]
  tempPermissions TemporaryPermission[]

  @@unique([module, action, scope])
  @@map("permissions")
}

model AdminRolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         AdminRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  granted      Boolean    @default(true)
  assignedBy   String?
  assignedAt   DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("admin_role_permissions")
}

model AdminUserRole {
  id         String    @id @default(cuid())
  userId     String
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String
  role       AdminRole @relation(fields: [roleId], references: [id])
  assignedBy String?
  assignedAt DateTime  @default(now())
  note       String?

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("admin_user_roles")
}

model TemporaryPermission {
  id           String     @id @default(cuid())
  userId       String
  user         AdminUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  reason       String?
  grantedBy    String
  validFrom    DateTime   @default(now())
  validUntil   DateTime
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())

  @@index([userId])
  @@map("temporary_permissions")
}

model ScopeAssignment {
  id         String    @id @default(cuid())
  userId     String
  user       AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopeType  String
  scopeId    String
  assignedBy String?
  assignedAt DateTime  @default(now())

  @@unique([userId, scopeType, scopeId])
  @@map("scope_assignments")
}

model AdminSession {
  id           String    @id @default(cuid())
  userId       String
  user         AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String    @unique
  ipAddress    String?
  userAgent    String?
  country      String?
  city         String?
  isSuspicious Boolean   @default(false)
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  @@index([userId])
  @@map("admin_sessions")
}

model AdminAllowedIP {
  id        String     @id @default(cuid())
  userId    String?
  user      AdminUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipRange   String
  label     String?
  createdBy String?
  createdAt DateTime   @default(now())

  @@index([userId])
  @@map("admin_allowed_ips")
}

model AuditLog {
  id           String     @id @default(cuid())
  adminId      String?
  admin        AdminUser? @relation(fields: [adminId], references: [id])
  adminName    String?
  action       String
  module       String
  targetId     String?
  targetLabel  String?
  previousData Json?
  newData      Json?
  ipAddress    String?
  userAgent    String?
  riskScore    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([adminId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@index([riskScore])
  @@map("audit_logs")
}

model PasswordPolicy {
  id                    String   @id @default(cuid())
  minLength             Int      @default(8)
  requireUppercase      Boolean  @default(true)
  requireLowercase      Boolean  @default(true)
  requireNumbers        Boolean  @default(true)
  requireSpecialChars   Boolean  @default(true)
  preventReuse          Int      @default(5)
  expiryDays            Int?
  maxFailedAttempts     Int      @default(5)
  lockoutDuration       Int      @default(30)
  sessionTimeoutMinutes Int      @default(480)
  require2FAForRoles    String[]
  updatedAt             DateTime @updatedAt

  @@map("password_policy")
}

// ─── SEO META YÖNETİMİ ───────────────────────────────────────────────────────

model SeoMeta {
  id                 String    @id @default(cuid())
  entityType         String    // "product"|"category"|"blog"|"campaign"|"page"
  entityId           String
  locale             String    @default("tr")

  title              String?
  description        String?
  keywords           String[]
  canonicalUrl       String?
  noIndex            Boolean   @default(false)
  noFollow           Boolean   @default(false)

  ogTitle            String?
  ogDescription      String?
  ogImage            String?
  ogType             String?   @default("website")

  twitterCard        String?   @default("summary_large_image")
  twitterTitle       String?
  twitterDescription String?
  twitterImage       String?

  schemaMarkup       Json?

  llmSummary         String?   @db.Text
  llmKeyFacts        Json?
  llmQaPairs         Json?
  llmEntityData      Json?
  llmLastOptimizedAt DateTime?
  llmOptimizedFor    String[]

  aiGenerated        Boolean   @default(false)
