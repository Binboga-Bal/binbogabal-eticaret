generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── KULLANICILAR ────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  emailVerified       DateTime?
  emailVerifyToken    String?   @unique
  password            String?
  name                String?
  phone               String?
  phoneVerified       Boolean   @default(false)
  avatarUrl           String?
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  role                UserRole  @default(CUSTOMER)
  isActive            Boolean   @default(true)
  scheduledDeleteAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  addresses             Address[]
  orders                Order[]
  reviews               Review[]
  sessions              Session[]
  accounts              Account[]
  favorites             Favorite[]
  customerCoupons       CustomerCoupon[]
  notificationPreference NotificationPreference?
  consentLogs           ConsentLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  CUSTOMER
  EDITOR
  ADMIN
  SUPERADMIN
}

// ─── ADRESLER ────────────────────────────────────────────────────────────────

model Address {
  id           String  @id @default(cuid())
  userId       String
  title        String
  firstName    String
  lastName     String
  phone        String
  city         String
  district     String
  neighborhood String?
  fullAddress  String  @db.Text
  zipCode      String?
  taxNumber    String?
  taxOffice    String?
  isDefault    Boolean @default(false)
  isBilling    Boolean @default(false)
  createdAt    DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─── KATEGORİLER ─────────────────────────────────────────────────────────────

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?    @db.Text
  image       String?
  parentId    String?
  order       Int        @default(0)
  isActive    Boolean    @default(true)
  showOnHome  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@map("categories")
}

// ─── ÜRÜNLER ─────────────────────────────────────────────────────────────────

model Product {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  shortDescription String?   @db.Text
  description      String?   @db.LongText
  metaTitle        String?
  metaDescription  String?
  images           Json
  isActive         Boolean   @default(true)
  isFeatured       Boolean   @default(false)
  isBestseller     Boolean   @default(false)
  isNew            Boolean   @default(false)
  erpProductCode   String?   @unique
  tasteNotes        Json?
  usageSuggestions  Json?
  analysisReportUrl String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  categories Category[]
  honeyTypes HoneyType[]
  variants   ProductVariant[]
  reviews    Review[]
  favorites  Favorite[]

  @@map("products")
}

model HoneyType {
  id        String    @id @default(cuid())
  slug      String    @unique
  label     String
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("honey_types")
}

model ProductVariant {
  id              String          @id @default(cuid())
  productId       String
  size            Int
  packagingType   PackagingType   @default(GLASS)
  price           Decimal         @db.Decimal(10, 2)
  discountedPrice Decimal?        @db.Decimal(10, 2)
  stock            Int             @default(0)
  maxOrderQuantity Int?
  sku              String?         @unique
  erpVariantCode   String?         @unique
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("product_variants")
}

enum PackagingType {
  GLASS
  PLASTIC
}

// ─── SİPARİŞLER ──────────────────────────────────────────────────────────────

model Order {
  id               String        @id @default(cuid())
  orderNumber      String        @unique
  userId           String?
  guestEmail       String?
  guestPhone       String?
  addressId        String?
  shippingAddress  Json
  status           OrderStatus   @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)
  subtotal         Decimal       @db.Decimal(10, 2)
  shippingFee      Decimal       @db.Decimal(10, 2) @default(0)
  discount         Decimal       @db.Decimal(10, 2) @default(0)
  total            Decimal       @db.Decimal(10, 2)
  couponCode       String?
  cargoTrackingNo  String?
  cargoCompany     String?
  notes            String?       @db.Text
  cancelReason     String?       @db.Text
  refundReason     String?       @db.Text
  reviewRequested  Boolean       @default(false)
  erpOrderCode     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user         User?                @relation(fields: [userId], references: [id])
  address      Address?             @relation(fields: [addressId], references: [id])
  items        OrderItem[]
  transactions PaymentTransaction[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  variantId   String
  quantity    Int
  price       Decimal @db.Decimal(10, 2)
  productName String
  variantInfo String
  image       String?
  reviewed    Boolean @default(false)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─── ÖDEME ───────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id              String            @id @default(cuid())
  orderId         String
  provider        PaymentProvider   @default(QNB_PAY)
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(10, 2)
  providerRefId   String?
  providerResponse Json?
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("payment_transactions")
}

enum PaymentProvider {
  QNB_PAY
  IYZICO
  STRIPE
  MANUAL
  CASH_ON_DELIVERY
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─── KAMPANYALAR ─────────────────────────────────────────────────────────────

model Campaign {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String?          @db.Text
  internalNote      String?          @db.Text
  type              CampaignType
  status            CampaignStatus   @default(DRAFT)
  priority          Int              @default(0)
  stackable         Boolean          @default(false)
  maxDiscountAmount Decimal?         @db.Decimal(10, 2)
  budgetLimit       Decimal?         @db.Decimal(10, 2)
  budgetUsed        Decimal          @default(0) @db.Decimal(10, 2)
  imageUrl          String?
  ogImageUrl        String?
  startsAt          DateTime
  endsAt            DateTime?
  timezone          String           @default("Europe/Istanbul")
  requiresApproval  Boolean          @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  createdBy         String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  conditions    CampaignCondition[]
  actions       CampaignAction[]
  segments      CampaignSegment[]
  targets       CampaignTarget[]
  coupons       Coupon[]
  abTests       CampaignABTest[]
  usages        CampaignUsage[]
  displays      CampaignDisplay[]
  notifications CampaignNotification[]
  translations  CampaignTranslation[]
  auditLogs     CampaignAuditLog[]
  templates     CampaignTemplate[]

  @@map("campaigns")
}

enum CampaignType {
  COUPON
  CART_DISCOUNT
  PRODUCT_DISCOUNT
  FREE_SHIPPING
  BUY_X_PAY_Y
  GIFT_PRODUCT
  FLASH_SALE
  CASHBACK
  BIRTHDAY
  WIN_BACK
  ABANDONED_CART
}

enum CampaignStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

model CampaignCondition {
  id         String        @id @default(cuid())
  campaignId String
  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       ConditionType
  operator   String
  value      Json
  logicGroup Int           @default(0)
  sortOrder  Int           @default(0)

  @@map("campaign_conditions")
}

enum ConditionType {
  MIN_CART_AMOUNT
  MIN_ITEM_COUNT
  SPECIFIC_PRODUCTS
  SPECIFIC_CATEGORIES
  SPECIFIC_BRANDS
  CUSTOMER_SEGMENT
  CUSTOMER_ORDER_COUNT
  CUSTOMER_TOTAL_SPEND
  FIRST_ORDER
  DAY_OF_WEEK
  TIME_OF_DAY
  GEOGRAPHIC
  DEVICE_TYPE
  PAYMENT_METHOD
  BIRTHDAY_MONTH
  DAYS_SINCE_LAST_ORDER
}

model CampaignAction {
  id         String     @id @default(cuid())
  campaignId String
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       ActionType
  value      Json
  sortOrder  Int        @default(0)

  @@map("campaign_actions")
}

enum ActionType {
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  FREE_SHIPPING
  BUY_X_PAY_Y
  GIFT_PRODUCT
  CASHBACK_POINTS
  FREE_PRODUCT
  CATEGORY_DISCOUNT
}

model CampaignSegment {
  id         String      @id @default(cuid())
  campaignId String
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       SegmentType
  value      Json

  @@map("campaign_segments")
}

enum SegmentType {
  ALL_CUSTOMERS
  NEW_CUSTOMERS
  VIP_CUSTOMERS
  INACTIVE_CUSTOMERS
  BIRTHDAY_THIS_MONTH
  SPECIFIC_CUSTOMERS
  CUSTOMER_TAG
  GEOGRAPHIC_SEGMENT
}

model CampaignTarget {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  discount   Decimal? @db.Decimal(10, 2)

  @@map("campaign_targets")
}

model CampaignUsage {
  id             String   @id @default(cuid())
  campaignId     String
  campaign       Campaign @relation(fields: [campaignId], references: [id])
  customerId     String?
  orderId        String?
  couponId       String?
  coupon         Coupon?  @relation(fields: [couponId], references: [id])
  discountAmount Decimal  @db.Decimal(10, 2)
  abVariant      String?
  usedAt         DateTime @default(now())

  @@index([campaignId])
  @@index([customerId])
  @@index([usedAt])
  @@map("campaign_usages")
}

model CampaignDisplay {
  id            String      @id @default(cuid())
  campaignId    String
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type          DisplayType
  placement     String
  imageUrl      String?
  title         String?
  subtitle      String?
  ctaText       String?
  ctaUrl        String?
  bgColor       String?
  textColor     String?
  showCountdown Boolean     @default(false)
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)

  @@map("campaign_displays")
}

enum DisplayType {
  BANNER
  POPUP
  FLOATING_BAR
  PRODUCT_BADGE
  CART_MESSAGE
}

model CampaignABTest {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  variantName  String
  trafficSplit Int
  discountValue Decimal @db.Decimal(10, 2)
  impressions  Int      @default(0)
  conversions  Int      @default(0)
  revenue      Decimal  @default(0) @db.Decimal(10, 2)
  isWinner     Boolean  @default(false)

  @@map("campaign_ab_tests")
}

model CampaignNotification {
  id            String           @id @default(cuid())
  campaignId    String
  campaign      Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type          NotificationType
  scheduledAt   DateTime?
  sentAt        DateTime?
  channel       String
  subject       String?
  body          String?          @db.Text
  targetSegment String?
  status        String           @default("PENDING")

  @@map("campaign_notifications")
}

enum NotificationType {
  CAMPAIGN_START
  CAMPAIGN_REMINDER
  CAMPAIGN_END
  FAVORITE_DISCOUNT
  ABANDONED_CART
  BIRTHDAY_COUPON
  WIN_BACK_COUPON
}

model CampaignTranslation {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  locale      String
  name        String
  description String?  @db.Text
  ctaText     String?

  @@unique([campaignId, locale])
  @@map("campaign_translations")
}

model CampaignTemplate {
  id          String    @id @default(cuid())
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  name        String
  description String?
  config      Json
  isSystem    Boolean   @default(false)
  createdBy   String
  createdAt   DateTime  @default(now())

  @@map("campaign_templates")
}

model CampaignAuditLog {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adminId    String
  action     String
  changes    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@map("campaign_audit_logs")
}

// ─── KUPONLAR ─────────────────────────────────────────────────────────────────

model Coupon {
  id               String           @id @default(cuid())
  campaignId       String?
  campaign         Campaign?        @relation(fields: [campaignId], references: [id])
  code             String           @unique
  description      String?
  discountType     DiscountType     @default(PERCENTAGE)
  discountValue    Decimal          @db.Decimal(10, 2)
  minOrderAmount   Decimal?         @db.Decimal(10, 2)
  maxDiscount      Decimal?         @db.Decimal(10, 2)
  maxUses          Int?
  perCustomerLimit Int?             @default(1)
  usedCount        Int              @default(0)
  isActive         Boolean          @default(true)
  isBulk           Boolean          @default(false)
  startsAt         DateTime?
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())

  customerCoupons CustomerCoupon[]
  usages          CampaignUsage[]

  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model CustomerCoupon {
  id          String    @id @default(cuid())
  userId      String
  couponId    String
  usedAt      DateTime?
  usedInOrder String?
  assignedAt  DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
  @@map("customer_coupons")
}

// ─── FAVORİLER ───────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

// ─── BİLDİRİM TERCİHLERİ ─────────────────────────────────────────────────────

model NotificationPreference {
  id                String  @id @default(cuid())
  userId            String  @unique
  orderUpdates      Boolean @default(true)
  favoriteDiscounts Boolean @default(true)
  couponReminders   Boolean @default(true)
  reviewRequests    Boolean @default(true)
  newsletter        Boolean @default(false)
  smsNotifications  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── KVKK ONAY LOGLARI ───────────────────────────────────────────────────────

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "kvkk" | "newsletter" | "sms"
  granted   Boolean
  ip        String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consent_logs")
}

// ─── DEĞERLENDİRMELER ────────────────────────────────────────────────────────

model Review {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  orderId     String?
  orderItemId String?
  rating      Int
  title       String?
  comment     String?  @db.Text
  images      Json?    // string[]
  isApproved  Boolean  @default(false)
  adminReply  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@map("reviews")
}

// ─── BLOG / İÇERİK ───────────────────────────────────────────────────────────

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  excerpt         String?   @db.Text
  content         String    @db.LongText
  coverImage      String?
  authorId        String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("blog_posts")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("faqs")
}

// ─── DIA ERP SYNC ────────────────────────────────────────────────────────────

model ErpSyncLog {
  id          String      @id @default(cuid())
  syncType    ErpSyncType
  status      SyncStatus  @default(PENDING)
  message     String?     @db.Text
  recordCount Int?
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  @@map("erp_sync_logs")
}

enum ErpSyncType {
  PRODUCTS
  STOCK
  ORDERS
  PRICES
}

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ─── SITE AYARLARI ───────────────────────────────────────────────────────────

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("site_settings")
}
