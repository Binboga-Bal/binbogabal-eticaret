  llmScore           Int?
  readabilityScore   Int?
  lastAuditedAt      DateTime?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([entityType, entityId, locale])
  @@index([entityType, locale])
  @@index([seoScore])
  @@index([llmScore])
  @@map("seo_meta")
}

